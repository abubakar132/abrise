# ─── GEMINI AI ───────────────────────────────────────────────
# Get from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── EMAIL NOTIFICATIONS (nodemailer via Gmail) ───────────────
# Your Gmail address (the one that sends notifications)
EMAIL_FROM=your_gmail@gmail.com
# Abu Bakar's email that receives lead alerts
EMAIL_TO=abubakar@example.com
# Gmail App Password (NOT your Gmail login password)
# Generate at: https://myaccount.google.com/apppasswords
EMAIL_APP_PASSWORD=your_gmail_app_password_here

# ─── GOOGLE SHEETS (lead database) ───────────────────────────
# 1. Create a Google Sheet, copy the ID from its URL
#    https://docs.google.com/spreadsheets/d/SHEET_ID_HERE/edit
GOOGLE_SHEET_ID=your_google_sheet_id_here
# 2. Create a Service Account in Google Cloud Console
#    Download the JSON key, paste the entire JSON as one line here
GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account","project_id":"..."}

# ─── CALENDLY ────────────────────────────────────────────────
# Your Calendly scheduling link (used as CTA inside chatbot)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/abubakar-abrise/discovery

# ─── WHATSAPP (optional — wa.me link for direct contact) ─────
NEXT_PUBLIC_WHATSAPP_NUMBER=923001234567
